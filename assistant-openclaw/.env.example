# OpenClaw runtime secrets (example only)
# Copy to ~/.openclaw/.env on target machine and fill real values.

# Gateway auth password
OPENCLAW_GATEWAY_PASSWORD="<CHANGE_ME>"

# Model provider key used in openclaw.json
MY_PROVIDER_API_KEY="<CHANGE_ME>"

# Optional: Tavily skill key
TAVILY_API_KEY="<OPTIONAL_CHANGE_ME>"
